VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Shown in Settings (must match INVOICE_SEND_DOMAIN in Supabase Edge secrets for send-invoice)
VITE_INVOICE_SEND_DOMAIN=mail.optimedix.ai

# Supabase Edge secrets (not Vite): SENDGRID_API_KEY, INVOICE_SEND_DOMAIN,
# SENDGRID_VERIFIED_FROM_EMAIL=verified@yourdomain.com  ← stops SendGrid "Invalid from" until domain auth
